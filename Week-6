<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>C Programming Quiz</title>

<style>

body{
font-family: Arial, sans-serif;
background: linear-gradient(135deg,#667eea,#764ba2);
margin:0;
padding:0;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
}

.quiz-container{
background:white;
width:700px;
padding:30px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

h1{
text-align:center;
color:#444;
margin-bottom:20px;
}

.question{
margin-bottom:20px;
padding:15px;
border-radius:8px;
background:#f3f3f3;
}

.options label{
display:block;
padding:8px;
margin:5px 0;
border-radius:5px;
cursor:pointer;
transition:0.3s;
}

.options label:hover{
background:#e0e0ff;
}

button{
width:100%;
padding:12px;
font-size:18px;
border:none;
border-radius:8px;
background:#667eea;
color:white;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:#4c5bd4;
}

.result{
text-align:center;
font-size:22px;
margin-top:20px;
font-weight:bold;
color:#333;
}

</style>
</head>

<body>

<div class="quiz-container">

<h1>C Programming Quiz</h1>

<form id="quizForm">

<div class="question">
<p>1. Who developed C language?</p>
<div class="options">
<label><input type="radio" name="q1" value="a"> Dennis Ritchie</label>
<label><input type="radio" name="q1" value="b"> James Gosling</label>
<label><input type="radio" name="q1" value="c"> Bjarne Stroustrup</label>
<label><input type="radio" name="q1" value="d"> Guido van Rossum</label>
</div>
</div>

<div class="question">
<p>2. Which symbol is used for single line comment?</p>
<div class="options">
<label><input type="radio" name="q2" value="a"> //</label>
<label><input type="radio" name="q2" value="b"> ##</label>
<label><input type="radio" name="q2" value="c"> **</label>
<label><input type="radio" name="q2" value="d"> %%</label>
</div>
</div>

<div class="question">
<p>3. What is the extension of C file?</p>
<div class="options">
<label><input type="radio" name="q3" value="a"> .java</label>
<label><input type="radio" name="q3" value="b"> .py</label>
<label><input type="radio" name="q3" value="c"> .c</label>
<label><input type="radio" name="q3" value="d"> .cpp</label>
</div>
</div>

<div class="question">
<p>4. Which function prints output?</p>
<div class="options">
<label><input type="radio" name="q4" value="a"> cout</label>
<label><input type="radio" name="q4" value="b"> printf()</label>
<label><input type="radio" name="q4" value="c"> print()</label>
<label><input type="radio" name="q4" value="d"> echo()</label>
</div>
</div>

<div class="question">
<p>5. Header file for printf?</p>
<div class="options">
<label><input type="radio" name="q5" value="a"> stdio.h</label>
<label><input type="radio" name="q5" value="b"> math.h</label>
<label><input type="radio" name="q5" value="c"> string.h</label>
<label><input type="radio" name="q5" value="d"> conio.h</label>
</div>
</div>

<div class="question">
<p>6. Size of int (commonly)?</p>
<div class="options">
<label><input type="radio" name="q6" value="a"> 2 bytes</label>
<label><input type="radio" name="q6" value="b"> 4 bytes</label>
<label><input type="radio" name="q6" value="c"> 8 bytes</label>
<label><input type="radio" name="q6" value="d"> 16 bytes</label>
</div>
</div>

<div class="question">
<p>7. Which loop runs at least once?</p>
<div class="options">
<label><input type="radio" name="q7" value="a"> for</label>
<label><input type="radio" name="q7" value="b"> while</label>
<label><input type="radio" name="q7" value="c"> do while</label>
<label><input type="radio" name="q7" value="d"> none</label>
</div>
</div>

<div class="question">
<p>8. Address operator in C?</p>
<div class="options">
<label><input type="radio" name="q8" value="a"> *</label>
<label><input type="radio" name="q8" value="b"> &</label>
<label><input type="radio" name="q8" value="c"> %</label>
<label><input type="radio" name="q8" value="d"> #</label>
</div>
</div>

<div class="question">
<p>9. Keyword used to return value?</p>
<div class="options">
<label><input type="radio" name="q9" value="a"> stop</label>
<label><input type="radio" name="q9" value="b"> break</label>
<label><input type="radio" name="q9" value="c"> return</label>
<label><input type="radio" name="q9" value="d"> exit</label>
</div>
</div>

<div class="question">
<p>10. Best loop when iterations known?</p>
<div class="options">
<label><input type="radio" name="q10" value="a"> for</label>
<label><input type="radio" name="q10" value="b"> while</label>
<label><input type="radio" name="q10" value="c"> do while</label>
<label><input type="radio" name="q10" value="d"> goto</label>
</div>
</div>

<button type="button" onclick="checkQuiz()">Submit Quiz</button>

</form>

<div class="result" id="result"></div>

</div>

<script>

function checkQuiz(){

let score = 0;

let answers = {
q1:"a",
q2:"a",
q3:"c",
q4:"b",
q5:"a",
q6:"b",
q7:"c",
q8:"b",
q9:"c",
q10:"a"
};

for(let q in answers){

let selected = document.querySelector('input[name="'+q+'"]:checked');

if(selected && selected.value === answers[q]){
score++;
}

}

document.getElementById("result").innerHTML =
"Your Score: "+score+" / 10";

}

</script>

</body>
</html>
